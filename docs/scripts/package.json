{
  "name": "ua-docs-exporter",
  "private": true,
  "type": "module",
  "scripts": {
    "export": "node export-game-data.mjs",
    "validate": "node validate-data-sync.mjs && node validate-rules-v2.mjs --allow-v1",
    "validate:legacy": "node validate-data-sync.mjs",
